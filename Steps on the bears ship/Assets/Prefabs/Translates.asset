  m_Script: {fileID: 11500000, guid: f8bdcb1ce0e55574a91c47c8b5666d95, type: 3}
  m_Name: Translates
  m_EditorClassIdentifier: 
  translations:
  - key: MainMenu_Continue
    translates:
    - variations:
      - "\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C: {name}"
    - variations:
      - 'Continue: {name}'
  - key: MainMenu_StartNewGame
    translates:
    - variations:
      - "\u041D\u0430\u0447\u0430\u0442\u044C \u043D\u043E\u0432\u0443\u044E \u0438\u0433\u0440\u0443"
    - variations:
      - Start new game
  - key: MainMenu_Load
    translates:
    - variations:
      - "\u0417\u0430\u0433\u0440\u0443\u0437\u0438\u0442\u044C \u0438\u0433\u0440\u0443"
    - variations:
      - Load game
  - key: MainMenu_Settings
    translates:
    - variations:
      - "\u041D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0438"
    - variations:
      - Settings
  - key: MainMenu_Quit
    translates:
    - variations:
      - "\u0412\u044B\u0439\u0442\u0438 \u0438\u0437 \u0438\u0433\u0440\u044B"
    - variations:
      - Exit the game
  - key: Settings_Back
    translates:
    - variations:
      - "\u0412\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F \u0432 \u043C\u0435\u043D\u044E"
    - variations:
      - Back to menu
  - key: Saves_Back
    translates:
    - variations:
      - "\u0412\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F \u0432 \u043C\u0435\u043D\u044E"
    - variations:
      - Back to menu
  - key: Saves_NewGame
    translates:
    - variations:
      - "\u0421\u043E\u0437\u0434\u0430\u0442\u044C \u043D\u043E\u0432\u043E\u0435
        \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0435"
    - variations:
      - Create new save
  - key: Saves_SaveName
    translates:
    - variations:
      - "\u0438\u043C\u044F \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u044F..."
    - variations:
      - save name...
  - key: Saves_LoadGame
    translates:
    - variations:
      - "\u0417\u0430\u0433\u0440\u0443\u0437\u0438\u0442\u044C \u0438\u0433\u0440\u0443"
    - variations:
      - Load game
  - key: QuickSaveName
    translates:
    - variations:
      - "\u0411\u0435\u0437 \u0438\u043C\u0435\u043D\u0438"
    - variations:
      - No name
  - key: Allert_Descripiton
    translates:
    - variations:
      - "\u0423 \u0432\u0430\u0441 \u0443\u0436\u0435 \u0435\u0441\u0442\u044C \u0430\u0432\u0442\u043E\u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0435.
        \u0412\u044B \u0443\u0432\u0435\u0440\u0435\u043D\u044B, \u0447\u0442\u043E
        \u0445\u043E\u0442\u0438\u0442\u0435 \u0435\u0433\u043E \u043F\u0435\u0440\u0435\u0437\u0430\u043F\u0438\u0441\u0430\u0442\u044C?"
    - variations:
      - You already have an autosave. Are you sure you want to overwrite it?
  - key: Allert_CreateNewGame
    translates:
    - variations:
      - "\u0414\u0430, \u044F \u0445\u043E\u0447\u0443 \u043F\u0435\u0440\u0435\u0437\u0430\u043F\u0438\u0441\u0430\u0442\u044C
        \u0430\u0432\u0442\u043E\u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0435"
    - variations:
      - Yes, I want to overwrite autosave
  - key: Allert_ExitAllertMenu
    translates:
    - variations:
      - "\u041D\u0435\u0442"
    - variations:
      - No
  - key: PauseBreak_Continue
    translates:
    - variations:
      - "\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C"
    - variations:
      - Continue
  - key: PauseBreak_Save
    translates:
    - variations:
      - "\u0421\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C"
    - variations:
      - Save
  - key: PauseBreak_Load
    translates:
    - variations:
      - "\u0417\u0430\u0433\u0440\u0443\u0437\u0438\u0442\u044C"
    - variations:
      - Load
  - key: PauseBreak_Settings
    translates:
    - variations:
      - "\u041D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0438"
    - variations:
      - Settings
  - key: PauseBreak_QuitToMain
    translates:
    - variations:
      - "\u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u043C\u0435\u043D\u044E"
    - variations:
      - Main menu
  - key: PauseBreak_Quit
    translates:
    - variations:
      - "\u0412\u044B\u0439\u0442\u0438 \u0438\u0437 \u0438\u0433\u0440\u044B"
    - variations:
      - Exit the game
  - key: PauseBreak_Settings_BackToTitle
    translates:
    - variations:
      - "\u0412\u0435\u0440\u043D\u0443\u0442\u044C\u044F \u043D\u0430\u0437\u0430\u0434"
    - variations:
      - Back
  - key: Substrate_Description
    translates:
    - variations:
      - "{name}. \u0421\u043E\u0437\u0434\u0430\u043D: {time}."
    - variations:
      - '{name}. Created: {time}.'
  - key: Substrate_Delete
    translates:
    - variations:
      - "\u0410\u043D\u043D\u0438\u0433\u0438\u043B\u0438\u0440\u043E\u0432\u0430\u0442\u044C"
      - "\u0423\u0434\u0430\u043B\u0438\u0442\u044C"
      - "\u0414\u0435\u043C\u043E\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u0442\u044C"
    - variations:
      - Annihilate
      - Delete
      - Dismantle
  - key: AutoSaveName
    translates:
    - variations:
      - "\u0410\u0432\u0442\u043E\u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0435"
    - variations:
      - Autosave
  - key: SaveUI_Saving...
    translates:
    - variations:
      - "\u0421\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0435..."
    - variations:
      - Saving...
  - key: SaveUI_Allert
    translates:
    - variations:
      - "\u0421\u0435\u0439\u0447\u0430\u0441 \u043D\u0435\u043B\u044C\u0437\u044F
        \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C\u0441\u044F!"
      - "\u041D\u0415\u041B\u042C\u0417\u042F \u0421\u041E\u0425\u0420\u0410\u041D\u0418\u0422\u042C\u0421\u042F!!!"
      - "\u0421\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0435 \u043D\u0435\u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E!"
    - variations:
      - You can't save now!
      - YOU CAN'T SAVE!!!
      - Saving is unavailable!
  - key: SaveUI_ExitAllert
    translates:
    - variations:
      - "\u0418\u0433\u0440\u0430 \u043F\u0440\u0438 \u0432\u044B\u0445\u043E\u0434\u0435
        \u043D\u0435 \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C\u0441\u044F "
    - variations:
      - The game won't save when exiting
  - key: Lose_Description
    translates:
    - variations:
      - " \u0412\u044B \u043F\u0440\u043E\u0438\u0433\u0440\u0430\u043B\u0438"
    - variations:
      - You lost
  - key: Lose_LoadLastSave
    translates:
    - variations:
      - "\u0417\u0430\u0433\u0440\u0443\u0437\u0438\u0442\u044C\u0441\u044F \u0441
        \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0433\u043E \u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u044F"
    - variations:
      - Load from the last save
  - key: Lose_ExitToMain
    translates:
    - variations:
      - "\u0412\u044B\u0439\u0442\u0438 \u0432 \u0433\u043B\u0430\u0432\u043D\u043E\u0435
        \u043C\u0435\u043D\u044E"
    - variations:
      - Exit to main menu
  - key: Lose_Exit
    translates:
    - variations:
      - "\u0412\u044B\u0439\u0442\u0438"
    - variations:
      - Exit
  - key: Win_Exit
    translates:
    - variations:
      - "\u0412\u044B\u0439\u0442\u0438 \u0432 \u043C\u0435\u043D\u044E"
    - variations:
      - Exit to menu
  - key: Win_Description1
    translates:
    - variations:
      - "\u042F \u0434\u043E\u0448\u0435\u043B \u0434\u043E \u0441\u043F\u0430\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u043E\u0439
        \u043A\u0430\u043F\u0441\u0443\u043B\u044B."
    - variations:
      - I reached the escape pod.
  - key: Win_Description2
    translates:
    - variations:
      - "\u041D\u043E \u043A\u0430\u0436\u0438\u0441\u044C \u0438 \u044F \u043D\u0435
        \u0441\u043F\u0430\u0441\u0443\u0441\u044C."
    - variations:
      - "But it seems I won\u2019t be saved either."
  - key: MishaRoom_Hint
    translates:
    - variations:
      - "\u041A\u0430\u0436\u0438\u0441\u044C \u043D\u0430 \u043A\u043E\u0440\u0430\u0431\u043B\u0435
        \u0447\u0442\u043E-\u0442\u043E \u0441\u043B\u0443\u0447\u0438\u043B\u043E\u0441\u044C...
        \u043F\u0440\u0435\u0434\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u044C
        \u043F\u0435\u0440\u0435\u0433\u043E\u0440\u0435\u043B, \u043D\u0443\u0436\u043D\u043E
        \u043D\u0430\u0439\u0442\u0438 \u043D\u043E\u0432\u044B\u0439 \u0438 \u0432\u0441\u0442\u0430\u0432\u0438\u0442\u044C
        \u0432 \u044D\u043B\u0435\u043A\u0442\u0440\u043E\u0449\u0438\u0442\u043E\u043A(\u043D\u0430\u0436\u043C\u0438\u0442\u0435
        \u043B\u043A\u043C \u0434\u043B\u044F \u0442\u043E\u0433\u043E, \u0447\u0442\u043E\u0431\u044B
        \u043F\u043E\u0434\u043D\u044F\u0442\u044C \u0438\u043B\u0438 \u0432\u0441\u0442\u0430\u0432\u0438\u0442\u044C
        \u043F\u0440\u0435\u0434\u043C\u0435\u0442 \u0438 \u043F\u043A\u043C, \u0447\u0442\u043E\u0431\u044B
        \u0431\u0440\u043E\u0441\u0438\u0442\u044C) "
    - variations:
      - Something seems to have happened on the ship... the fuse has blown, you need
        to find a new one and insert it into the electrical panel (left-click to
        pick up or insert an object, right-click to throw)
  - key: Corridor_Hint
    translates:
    - variations:
      - "\u041A\u0430\u0436\u0438\u0441\u044C \u043D\u0430\u0441 \u043D\u0435\u043F\u043B\u043E\u0445\u043E
        \u0442\u0440\u044F\u0445\u043D\u0443\u043B\u043E, \u0432\u0441\u0435 \u044F\u0449\u0438\u043A\u0438
        \u0440\u0430\u0437\u0431\u0440\u043E\u0441\u0430\u043D\u044B. \u0415\u0449\u0435
        \u043F\u043E\u0432\u0441\u044E\u0434\u0443 \u044D\u0442\u0430 \u0441\u0442\u0440\u0430\u043D\u043D\u0430\u044F
        \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u044C, \u043D\u0443\u0436\u043D\u043E
        \u043F\u043E\u0441\u043A\u043E\u0440\u0435\u0435 \u043D\u0430\u0439\u0442\u0438
        \u043A\u043E\u043C\u0430\u043D\u0434\u0443. \u041C\u043E\u0436\u0435\u0442
        \u0431\u044B\u0442\u044C \u0442\u0443\u0442 \u0435\u0441\u0442\u044C \u044F\u0449\u0438\u043A,
        \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u044F \u0441\u043C\u043E\u0433\u0443
        \u0441\u0434\u0432\u0438\u043D\u0443\u0442\u044C?(\u0437\u0430\u0436\u043C\u0438\u0442\u0435
        \u043B\u043A\u043C \u0434\u043B\u044F \u0432\u0437\u0430\u0438\u043C\u043E\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
        \u0441 \u043E\u0431\u044A\u0435\u043A\u0442\u0430\u043C\u0438 \u0438 \u0434\u0432\u0438\u0433\u0430\u0442\u0435\u0441\u044C
        \u0434\u043B\u044F \u0442\u043E\u0433\u043E, \u0447\u0442\u043E\u0431\u044B
        \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0430\u0442\u044C \u043E\u0431\u044A\u0435\u043A\u0442\u044B)"
    - variations:
      - It looks like we got shaken pretty bad; all the boxes are scattered. There's
        also this weird liquid everywhere; we need to find the team quickly. Maybe
        there's a box here I can move? (Hold left-click to interact with objects
        and move to move objects.)
  - key: Corridor_Hint2
    translates:
    - variations:
      - "\u0412\u043E\u0442 \u0437\u0430\u0440\u0430\u0437\u0430, \u043F\u0440\u043E\u0445\u043E\u0434
        \u0432 \u0440\u0435\u0430\u043A\u0442\u043E\u0440 \u0437\u0430\u0432\u0430\u043B\u0438\u043B\u043E,
        \u043C\u043E\u0436\u0435\u0442 \u0432 \u043A\u043E\u043C\u043D\u0430\u0442\u0435
        \u0430\u043D\u0434\u0440\u043E\u043C\u0435\u0434\u044B \u044F \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C
        \u043D\u0430\u0439\u0434\u0443? \u041D\u0443\u0436\u043D\u043E \u043F\u0440\u0438\u0441\u0435\u0441\u0442\u044C,
        \u0447\u0442\u043E\u0431\u044B \u043F\u0440\u043E\u0439\u0442\u0438(\u043D\u0430\u0436\u043C\u0438\u0442\u0435
        ctrl)."
    - variations:
      - Damn it, the passage to the reactor is blocked. Maybe I'll find something
        in the Andromeda room? I need to crouch to get through (press ctrl).
  - key: AndromedaRoom_Hint
    translates:
    - variations:
      - "\u0427\u0442\u043E \u0442\u0443\u0442 \u043F\u0440\u043E\u0438\u0437\u043E\u0448\u043B\u043E?
        \u0413\u0434\u0435 \u0410\u043D\u0434\u0440\u043E\u043C\u0435\u0434\u0430?
        \u041D\u0443\u0436\u043D\u043E \u043F\u043E\u0441\u043A\u043E\u0440\u0435\u0435
        \u043F\u043E\u043F\u0430\u0441\u0442\u044C \u0432 \u043A\u043E\u043C\u043D\u0430\u0442\u0443
        \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F, \u043D\u043E
        \u043F\u0440\u043E\u0445\u043E\u0434 \u0437\u0430\u0431\u043B\u043E\u043A\u0438\u0440\u043E\u0432\u0430\u043D...
        \u043D\u0443\u0436\u043D\u043E \u043E\u0442\u043A\u0440\u044B\u0442\u044C
        \u0432\u0435\u043D\u0442\u0438\u043B\u044F\u0446\u0438\u044E, \u0432\u0440\u043E\u0434\u0435-\u0431\u044B
        \u043A\u043D\u043E\u043F\u043A\u0438 \u0434\u043B\u044F \u0435\u0451 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
        \u043A\u0440\u0430\u0441\u043D\u044B\u0435(\u043D\u0430\u0436\u043C\u0438\u0442\u0435
        \u043B\u043A\u043C \u043F\u043E \u043E\u0431\u044A\u0435\u043A\u0442\u0443
        \u0434\u043B\u044F \u0430\u043A\u0442\u0438\u0432\u0446\u0438\u0438)"
    - variations:
      - What happened here? Where's Andromeda? We need to get to the control room
        quickly, but the passage is blocked... I need to open the ventilation; the
        buttons for it are red (left-click on the object to activate it).
  - key: Reactor_Hint
    translates:
    - variations:
      - "\u041F\u0440\u043E\u0445\u043E\u0434 \u0432 \u043A\u0430\u043F\u0438\u0442\u0430\u043D\u0441\u043A\u0443\u044E
        \u0440\u0443\u0431\u043A\u0443 \u0437\u0430\u0431\u043B\u043E\u043A\u0438\u0440\u043E\u0432\u0430\u043D,
        \u043D\u0443\u0436\u043D\u043E \u043F\u0440\u043E\u0439\u0442\u0438 \u0447\u0435\u0440\u0435\u0437
        \u043A\u0443\u0445\u043D\u044E. \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E
        \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C\u0441\u044F \u043D\u0430\u0439\u0442\u0438
        \u0421\u0435\u0440\u0433\u0435\u044F, \u043E\u043D \u0447\u0430\u0441\u0442\u043E
        \u0442\u0430\u043C \u0431\u044B\u0432\u0430\u0435\u0442."
    - variations:
      - The passage to the captain's cabin is blocked; you'll need to go through
        the kitchen. You might be able to find Sergei; he's often there.
  - key: Kitchen_Hint
    translates:
    - variations:
      - "\u041A\u0430\u0436\u0438\u0441\u044C \u0421\u0435\u0440\u0433\u0435\u044F
        \u043F\u043E\u0433\u043B\u0430\u0442\u0438\u043B\u043E \u044D\u0442\u043E\u0439
        \u0436\u0438\u0434\u043A\u043E\u0441\u0442\u044C\u044E, \u044F \u0431\u044B
        \u043D\u0435 \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0430\u043B\u0441\u044F
        \u043A \u043D\u0435\u043C\u0443. \u041E\u043D \u043A\u043E\u043D\u0435\u0447\u043D\u043E
        \u0445\u043E\u0440\u043E\u0448\u043E \u0441\u043B\u044B\u0448\u0438\u0442
        \u0438 \u0447\u0443\u0435\u0442, \u043D\u043E \u0431\u0435\u0437 \u043E\u0447\u043A\u043E\u0432
        \u043C\u0435\u043D\u044F \u0438 \u0432 \u043F\u043B\u043E\u0442\u043D\u0443\u044E
        \u043D\u0435 \u0443\u0432\u0438\u0434\u0438\u0442. \u041D\u0443\u0436\u043D\u043E
        \u043F\u0435\u0440\u0435\u043A\u0440\u044B\u0442\u044C \u043F\u0430\u0440.(\u043D\u0430\u0439\u0434\u0438\u0442\u0435
        4 \u0432\u0435\u043D\u0442\u0435\u043B\u044F \u0438 \u043A\u0440\u0443\u0442\u0438\u0442\u0435
        \u0434\u043E \u0443\u043F\u043E\u0440\u0430, \u0437\u0430\u0436\u0430\u0432
        \u043B\u043A\u043C \u0438 \u0434\u0432\u0438\u0433\u0430\u044F \u043C\u044B\u0448\u043A\u043E\u0439)"
    - variations:
      - I think Sergey was swallowed by the liquid; I wouldn't go near him. He can
        hear and smell well, of course, but without his glasses he won't even be
        able to see me closely. You need to shut off the steam (find the four valves
        and turn them all the way, left-clicking and moving the mouse).
  - key: ControlRoom_Hint
    translates:
    - variations:
      - "\u0412\u043E\u0442 \u0447\u0435\u0440\u0442, \u044D\u0442\u043E \u0410\u043B\u0438\u043D\u0430.
        \u041E\u043D\u0430 \u0432\u0441\u0435\u0433\u0434\u0430 \u0437\u043D\u0430\u043B\u0430
        \u0433\u0434\u0435 \u043C\u0435\u043D\u044F \u043D\u0430\u0439\u0442\u0438,
        \u043F\u0440\u0430\u0432\u0434\u0430 \u0432 \u043D\u0430\u0448\u0435\u0439
        \u043A\u043E\u043C\u0430\u043D\u0434\u0435 \u043E\u043D\u0430 \u0445\u0443\u0434\u0448\u0430\u044F
        \u043F\u043E \u0444\u0438\u0437-\u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0435,
        \u0432\u0440\u044F\u0442\u043B\u0438 \u043E\u043D\u0430 \u043C\u0435\u043D\u044F
        \u0434\u043E\u0433\u043E\u043D\u0438\u0442, \u0435\u0441\u043B\u0438 \u043D\u0435
        \u0437\u0430\u0436\u043C\u0435\u0442 \u0432 \u0443\u0433\u043E\u043B. \u041A\u0430\u0436\u0438\u0441\u044C
        \u043A\u0442\u043E-\u0442\u043E \u0432\u044B\u043D\u0443\u043B \u0432\u0441\u0435
        \u043F\u0440\u0435\u0434\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u0435\u043B\u0438.
        \u041D\u0443\u0436\u043D\u043E \u0438\u0445 \u043D\u0430\u0439\u0442\u0438
        \u0438 \u0432\u0441\u0442\u0430\u0432\u0438\u0442\u044C \u0432 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u043C
        \u043F\u043E\u0440\u044F\u0434\u043A\u0435.\u041A\u0430\u043A\u043E\u0439
        \u043F\u0440\u0435\u043A\u0440\u0430\u0441\u043D\u044B\u0439 \u0432\u0438\u0434
        \u0437\u0430 \u043E\u043A\u043D\u043E\u043C!"
    - variations:
      - Damn, it's Alina. She always knew where to find me, though she's the worst
        physically fit on our team, so it's unlikely she'll catch me unless she corners
        me. Someone must have pulled all the fuses. I need to find them and put them
        back in the right order. What a beautiful view out the window!
