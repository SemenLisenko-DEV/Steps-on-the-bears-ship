MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f8bdcb1ce0e55574a91c47c8b5666d95, type: 3}
  m_Name: Translates
  m_EditorClassIdentifier: 
  translations:
  - key: StartNewGame
    translates:
    - "\u041D\u0430\u0447\u0430\u0442\u044C \u043D\u043E\u0432\u0443\u044E \u0438\u0433\u0440\u0443"
    - Start new game
  - key: ContinueGame
    translates:
    - "\u0417\u0430\u0433\u0440\u0443\u0437\u0438\u0442\u044C"
    - Load
  - key: SettingsMainMenu
    translates:
    - "\u041D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0438"
    - Settings
  - key: QuitMainMenu
    translates:
    - "\u0412\u044B\u0439\u0442\u0438 \u0438\u0437 \u0438\u0433\u0440\u044B"
    - Exit the game
  - key: BackFromSettingsMainMenu
    translates:
    - "\u0412\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F \u0432 \u043C\u0435\u043D\u044E"
    - Back to menu
  - key: Allert_RewriteSave
    translates:
    - "\u0412\u044B \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u044B, \u0447\u0442\u043E
      \u0445\u043E\u0442\u0438\u0442\u0435 \u0441\u043E\u0437\u0434\u0430\u0442\u044C
      \u043D\u043E\u0432\u0443\u044E \u0438\u0433\u0440\u0443?\u042D\u0442\u043E
      \u043F\u0435\u0440\u0435\u0437\u0430\u043F\u0438\u0448\u0435\u0442 \u0432\u0430\u0448\u0435
      \u0442\u0435\u043A\u0443\u0449\u0438\u0435 \u0430\u0432\u0442\u043E\u0441\u043E\u0445\u0440\u0430\u043D\u0435\u043D\u0438\u0435"
    - Are you sure you want to create a new game? This will overwrite your current
      autosave.
  - key: Allert_CreateNewGame
    translates:
    - "\u0414\u0430, \u044F \u0445\u043E\u0447\u0443 \u0441\u043E\u0437\u0434\u0430\u0442\u044C
      \u043D\u043E\u0432\u0443\u044E \u0438\u0433\u0440\u0443"
    - Yes, I want to create a new game
  - key: Allert_ExitAllertMenu
    translates:
    - "\u041D\u0435\u0442"
    - No
  - key: PauseBreak_Continue
    translates:
    - "\u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442\u044C"
    - Continue
  - key: PauseBreak_Save
    translates:
    - "\u0421\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C\u0441\u044F"
    - Save
  - key: PauseBreak_Settings
    translates:
    - "\u041D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0438"
    - Settings
  - key: PauseBreak_QuitToMain
    translates:
    - "\u0412\u044B\u0439\u0442\u0438 \u0432 \u0433\u043B\u0430\u0432\u043D\u043E\u0435
      \u043C\u0435\u043D\u044E"
    - Back to main menu
  - key: PauseBreak_Quit
    translates:
    - "\u0412\u044B\u0439\u0442\u0438 \u0438\u0437 \u0438\u0433\u0440\u044B"
    - Exit the game
  - key: PauseBreak_Settings_BackToTitle
    translates:
    - "\u0412\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F \u0432 \u043C\u0435\u043D\u044E"
    - Back to menu
